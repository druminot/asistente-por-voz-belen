# Belen — Asistente por Voz para macOS
# Copy to .env and fill in your values

# ─── OpenCode (cerebro) ─────────────────────────────────
# Path al binario de opencode (instala con: curl -fsSL https://opencode.ai/install | bash)
OPENCODE_BIN=opencode
# Modelo LLM a usar. Formato: provider/model
# Opciones probadas en opencode (jun-2026):
#   - ollama-cloud/glm-5.1           (default — Zhipu AI flagship, agentic, comparable a Claude Opus 4.6)
#   - ollama-cloud/glm-5.2
#   - ollama-cloud/glm-4.7
#   - ollama-cloud/minimax-m3
#   - ollama-cloud/qwen3.5:397b
#   - ollama-cloud/qwen3-coder-next
#   - ollama-cloud/deepseek-v3.2
# Listá todos con: opencode models
# NOTA: "qwen3.6" no existe. Las versiones de Qwen disponibles son 3.5 y 3-coder.
OPENCODE_MODEL=ollama-cloud/glm-5.1
# URL de Ollama
OPENCODE_BASE_URL=http://localhost:11434/v1
# Agente opencode (opcional, ej: 'build', 'plan')
OPENCODE_AGENT=

# ─── Hotkey (push-to-talk) ───────────────────────────────
# Combinación: option=Alt/Option, cmd, ctrl, shift + tecla
# Ejemplos: option+z+comma, cmd+shift+b, option+b
BELEN_HOTKEY=option+z+comma
# Modo: 'push_to_talk' (mantener) o 'toggle' (apretar y soltar)
BELEN_HOTKEY_MODE=push_to_talk

# ─── Wake word ──────────────────────────────────────────
# true / false — apagar si consume demasiada CPU
BELEN_WAKEWORD_ENABLED=true
# Palabra de activación (default: "belen")
BELEN_WAKEWORD=belen

# ─── STT (voz → texto) ──────────────────────────────────
# Motor: 'vibevoice-asr' o 'faster-whisper' (fallback)
BELEN_STT_ENGINE=faster-whisper
# Idioma para Whisper fallback: es, en, auto
BELEN_STT_LANG=es
# Tamaño modelo Whisper si se usa: tiny, base, small, medium, large-v3
# tiny=39MB, base=74MB, small=244MB, medium=769MB, large-v3=1.5GB
BELEN_WHISPER_MODEL=base

# ─── TTS (texto → voz) ──────────────────────────────────
# Motor: 'vibevoice-realtime', 'piper', 'macos-say'
BELEN_TTS_ENGINE=vibevoice-realtime
# Voz (depende del motor):
#   vibevoice-realtime: es_female, es_male, en_female, en_male
#   piper: es_ES-davefx, es_ES-sharvard, etc.
#   macos-say: Mónica, Paulina, Jorge, etc.
BELEN_TTS_VOICE=es_female

# ─── Proyectos ──────────────────────────────────────────
# Carpeta raíz donde están tus proyectos (para el selector por voz)
BELEN_PROJECTS_DIR=/Users/druminot/Documents/Codigos Varios
# Proyecto por defecto (vacío = directorio actual al lanzar)
BELEN_DEFAULT_PROJECT=

# ─── UI ─────────────────────────────────────────────────
# Mostrar indicador flotante con estado (gris/rojo/amarillo/verde)
BELEN_FLOATING_UI=true

# ─── Audio ───────────────────────────────────────────────
# Dispositivo de entrada (vacío = default)
BELEN_INPUT_DEVICE=
# Sample rate
BELEN_SAMPLE_RATE=16000

# ─── Seguridad ──────────────────────────────────────────
# Permitir que opencode edite archivos (true) o solo lectura (false)
BELEN_ALLOW_FILE_EDIT=true
# Carpeta raíz permitida para opencode (vacío = proyecto actual)
BELEN_ALLOWED_ROOT=

# ─── Debug ──────────────────────────────────────────────
# Guardar recordings en models/recordings/
BELEN_SAVE_RECORDINGS=false
# Nivel de log: DEBUG, INFO, WARNING, ERROR
BELEN_LOG_LEVEL=INFO
